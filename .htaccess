Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow the real index file
  RewriteRule ^index\.html$ - [L]

  # Do not rewrite API or uploaded files
  RewriteRule ^api/ - [L]
  RewriteRule ^uploads/ - [L]

  # Let existing files and folders pass through
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # React SPA fallback
  RewriteRule . /index.html [L]
</IfModule>
